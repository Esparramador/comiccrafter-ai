<section class="cc-app-download">
  <div class="cc-container">
    <div class="cc-app-download__grid">
      <div class="cc-app-download__content cc-animate-on-scroll">
        <div class="cc-hero__eyebrow">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          {{ section.settings.eyebrow | default: 'Disponible en todas las plataformas' }}
        </div>
        <h2 class="cc-section-title" style="font-size: 2.5rem;">
          {{ section.settings.title | default: 'Lleva Comic Crafter' }}
          <span class="cc-hero__title-gradient">{{ section.settings.title_gradient | default: 'en tu bolsillo' }}</span>
        </h2>
        <p class="cc-hero__subtitle" style="max-width: 500px;">
          {{ section.settings.description | default: 'Instala la app directamente desde tu navegador. Sin tienda de apps, sin esperas. Crea cómics, modelos 3D y voces IA donde quieras.' }}
        </p>
        <div class="cc-hero__actions" style="flex-wrap: wrap;">
          <a href="{{ section.settings.app_url | default: 'https://app.comiccrafter.es' }}" class="cc-btn cc-btn--primary cc-btn--lg" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Instalar App (PWA)
          </a>
          <a href="{{ section.settings.play_url | default: '#' }}" class="cc-btn cc-btn--secondary cc-btn--lg" {% if section.settings.play_url == blank %}onclick="alert('Próximamente en Google Play Store'); return false;"{% endif %}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Google Play
          </a>
        </div>
      </div>
      <div class="cc-app-download__mockup cc-animate-on-scroll">
        <div class="cc-app-download__phone">
          <div class="cc-app-download__screen">
            <div style="background: #0B0D17; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; padding: 20px;">
              <img src="{{ 'logo-app.png' | asset_url }}" alt="Comic Crafter" style="width: 64px; height: 64px; border-radius: 16px;" />
              <span style="font-size: 14px; font-weight: 800; color: #fff;">Comic Crafter</span>
              <span style="font-size: 10px; color: rgba(255,255,255,0.4);">IA Stories Platform</span>
              <div style="display: flex; gap: 8px; margin-top: 12px;">
                <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(147,51,234,0.1); display: flex; align-items: center; justify-content: center;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(59,130,246,0.1); display: flex; align-items: center; justify-content: center;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(6,182,212,0.1); display: flex; align-items: center; justify-content: center;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cc-app-download { padding: 6rem 0; position: relative; }
  .cc-app-download__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .cc-app-download__phone {
    width: 220px; height: 440px; margin: 0 auto;
    background: #1a1d35; border: 2px solid rgba(255,255,255,0.1);
    border-radius: 36px; padding: 12px; position: relative;
    box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 40px rgba(147,51,234,0.1);
  }
  .cc-app-download__phone::before {
    content: ''; position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
    width: 60px; height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px;
  }
  .cc-app-download__screen {
    width: 100%; height: 100%; border-radius: 24px; overflow: hidden;
    background: #0B0D17;
  }
  @media (max-width: 768px) {
    .cc-app-download__grid { grid-template-columns: 1fr; text-align: center; }
    .cc-app-download__content .cc-hero__actions { justify-content: center; }
    .cc-app-download__content .cc-hero__subtitle { margin: 0 auto; }
  }
</style>

{% schema %}
{
  "name": "Descargar App",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Subtítulo", "default": "Disponible en todas las plataformas" },
    { "type": "text", "id": "title", "label": "Título", "default": "Lleva Comic Crafter" },
    { "type": "text", "id": "title_gradient", "label": "Título gradiente", "default": "en tu bolsillo" },
    { "type": "textarea", "id": "description", "label": "Descripción", "default": "Instala la app directamente desde tu navegador. Sin tienda de apps, sin esperas. Crea cómics, modelos 3D y voces IA donde quieras." },
    { "type": "url", "id": "app_url", "label": "URL de la App (PWA)" },
    { "type": "url", "id": "play_url", "label": "URL de Google Play" }
  ],
  "presets": [{ "name": "Descargar App" }]
}
{% endschema %}
